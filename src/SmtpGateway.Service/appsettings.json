{
  // See SmtpGateway.Infrastructure.GatewayOptions for the bound type and validation rules.
  // No hot reload: the service must be restarted after any change to this file.
  "Gateway": {
    "Smtp": {
      // Loopback-only bind endpoints ("127.0.0.1:port" or "[::1]:port"). Non-loopback addresses
      // are rejected at startup.
      "BindEndpoints": [ "127.0.0.1:2525" ],
      "ServerName": "smtpoauth",
      // 25 MB, the MVP default.
      "MaxMessageSizeBytes": 26214400,
      "MaxRecipients": 100,
      "IdleTimeout": "00:01:00"
    },
    // Root directory of the durable raw-MIME file spool.
    "SpoolDirectory": "C:\\ProgramData\\SmtpGateway\\spool",
    // Path of the SQLite queue database file.
    "QueueDatabasePath": "C:\\ProgramData\\SmtpGateway\\queue.db",
    // How long an undelivered message stays queued before it is expired (capped at 5 days).
    "QueueTtl": "5.00:00:00",
    // How long the outbound delivery worker holds a queue item leased while attempting delivery.
    "LeaseDuration": "00:05:00",
    // Optional: rewrite the MIME "From:" header to this address before outbound submission.
    // Leave null/omit to send unchanged.
    "SenderRewriteAddress": null,
    // How long to wait after finding an empty queue before checking again.
    "DeliveryPollInterval": "00:00:05",
    // How often to sweep the queue for TTL-expired items.
    "TtlSweepInterval": "00:15:00",
    "OutboundProvider": {
      // Exactly one of "GenericSmtp", "M365Oauth", "Graph" is active; only that section's
      // settings need to be populated.
      "Provider": "GenericSmtp",
      "GenericSmtp": {
        "Host": "smtp.example.com",
        "Port": 587,
        // StartTlsRequired | SslOnConnect | None
        "TlsMode": "StartTlsRequired",
        // None | UsernamePassword | M365Oauth
        "AuthMode": "UsernamePassword",
        "Username": "REPLACE_WITH_YOUR_SMTP_USERNAME",
        "Password": "REPLACE_WITH_YOUR_SMTP_PASSWORD",
        "TrustAllCertificates": false
      },
      // Only used when Provider is "M365Oauth" (Microsoft 365 via SMTP, smtp.office365.com:587,
      // MSAL client-credentials OAuth).
      "M365Oauth": {
        "TenantId": "REPLACE_WITH_YOUR_TENANT_ID",
        "ClientId": "REPLACE_WITH_YOUR_CLIENT_ID",
        "ClientSecret": "REPLACE_WITH_YOUR_CLIENT_SECRET",
        "Mailbox": "REPLACE_WITH_YOUR_MAILBOX@example.com"
      },
      // Only used when Provider is "Graph" (Microsoft Graph raw-MIME sendMail, MSAL
      // client-credentials OAuth).
      "Graph": {
        "TenantId": "REPLACE_WITH_YOUR_TENANT_ID",
        "ClientId": "REPLACE_WITH_YOUR_CLIENT_ID",
        "ClientSecret": "REPLACE_WITH_YOUR_CLIENT_SECRET",
        "Mailbox": "REPLACE_WITH_YOUR_MAILBOX@example.com"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
