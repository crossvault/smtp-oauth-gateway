# Live E2E test credentials for the O365 dev sandbox tenant.
# Copy this file to `.env` (already gitignored) and fill in real values.
# Used only by SmtpGateway.E2ETests, which is excluded from normal `dotnet test` / CI runs.
#
# Fallback: for each key below, a non-blank value in `.env` wins; if a key is missing or blank the
# test loader falls back to the process environment variable of the SAME name. That is how the
# `.github/workflows/e2e.yml` workflow supplies these as GitHub Actions secrets (identical names)
# without a `.env` file. If neither source has a value, the live tests self-skip.

SMTPGATEWAY_E2E_TENANT_ID=
SMTPGATEWAY_E2E_CLIENT_ID=
SMTPGATEWAY_E2E_CLIENT_SECRET=

# Mailbox the app is granted SendAs / SMTP.SendAsApp + Mail.Send on (used as sender for both
# the M365 SMTP OAuth and Graph provider tests).
SMTPGATEWAY_E2E_SENDER_MAILBOX=

# A second sandbox mailbox to receive test messages (can be another address from the same tenant).
SMTPGATEWAY_E2E_RECIPIENT_MAILBOX=

# Comma-separated list of at least 3 additional sandbox mailboxes, used by the CC/BCC and
# multi-recipient content tests.
SMTPGATEWAY_E2E_RECIPIENT_MAILBOXES=
